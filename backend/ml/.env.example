# ── Google Cloud Vision ─────────────────────────────────────────────────────
# Path to GCP service account JSON key file (for Vision API access)
# Create at: GCP Console → IAM → Service Accounts → Create Key (JSON)
# Required role: roles/cloudvision.user
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── HuggingFace ─────────────────────────────────────────────────────────────
# Only required if the junwatu/indonesian-recipes dataset becomes gated.
# Get a token at: https://huggingface.co/settings/tokens
# Leave empty if dataset is public.
HUGGINGFACE_TOKEN=
